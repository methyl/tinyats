#!/usr/bin/env bash
# Pre-commit hook: run the test suite before allowing a commit.
# Skip with: git commit --no-verify
set -euo pipefail

echo "Running tests before commit..."

if command -v bun >/dev/null 2>&1; then
  bun run test
else
  echo "bun not found on PATH; falling back to npm" >&2
  npm test
fi
